{
  "name": "social-is-monorepo",
  "version": "1.0.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.0",
    "@types/leaflet": "^1.9.21",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0"
  },
  "private": true,
  "scripts": {
    "install:all": "bun install",
    "dev:back": "cd backend && bun run dev",
    "dev:front": "cd frontend && bun run dev",
    "dev": "concurrently \"bun run dev:back\" \"bun run dev:front\"",
    "lab:chaos": "cd scripts && sh chaos_devs.sh",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:back": "eslint backend --ext .ts,.js",
    "lint:front": "eslint frontend --ext .ts,.tsx,.js,.jsx"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "dependencies": {
    "leaflet": "^1.9.4",
    "react-leaflet": "^5.0.0"
  }
}
