{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "paths": {
      "@prisma/client": ["./node_modules/.prisma/client"],
      "@prisma/client/*": ["./node_modules/.prisma/client/*"],

      "@config/*": ["./config/*"],
      "@modules/*": ["./modules/*"],
      "@middleware/*": ["./middleware/*"],
      "@routes/*": ["./routes/*"],
      "@services/*": ["./services/*"],
      "@utils/*": ["./utils/*"]
    },

    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "outDir": "dist",
    "rootDir": "src"
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "scripts"]
}
