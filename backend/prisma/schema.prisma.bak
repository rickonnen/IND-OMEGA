  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA
  CUARTO
  TERRENO_MORTUORIO

  @@map("Categoria")
}

enum EstadoBlog {
  BORRADOR
  PENDIENTE
  PUBLICADO
  RECHAZADO
}

enum public_EstadoInmueble {
  ACTIVO
  INACTIVO
  VENDIDO
  ALQUILADO
  RESERVADO

  @@map("EstadoInmueble")
}

enum public_EstadoPublicacion {
  ACTIVA
  PAUSADA
  ELIMINADA

  @@map("EstadoPublicacion")
}

enum public_Genero {
  MASCULINO
  FEMENINO
  OTRO
  PREFIERO_NO_DECIR

  @@map("Genero")
}

enum public_TipoAccion {
  VENTA
  ALQUILER
  ANTICRETO

  @@map("TipoAccion")
}

enum public_TipoInteraccion {
  CLICK
  HOVER
  ZOOM
  DRAG

  @@map("TipoInteraccion")
}

enum public_TipoMarcador {
  NORMAL
  DESTACADO
  CLUSTER

  @@map("TipoMarcador")
}

enum public_TipoMultimedia {
  IMAGEN
  VIDEO

  @@map("TipoMultimedia")
}

enum estado_blog {
  BORRADOR
  PENDIENTE
  PUBLICADO
  RECHAZADO
}

enum DeviceMessage {
  ios
  android
  web
  unknown
  desktop
}

enum DifyBotType {
  chatBot
  textGenerator
  agent
  workflow
}

enum InstanceConnectionStatus {
  open
  close
  connecting
}

enum OpenaiBotType {
  assistant
  chatCompletion
}

enum SessionStatus {
  opened
  closed
  paused
}

enum TriggerOperator {
  contains
  equals
  startsWith
  endsWith
  regex
}

enum TriggerType {
  all
  keyword
  none
  advanced
}
