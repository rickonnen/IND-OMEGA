generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id       Int       @id @default(autoincrement())
  nombre   RolNombre @unique
  usuarios Usuario[]

  @@map("rol")
}

model Usuario {
  id                                    Int                           @id @default(autoincrement())
  nombre                                String
  apellido                              String
  correo                                String                        @unique
  password                              String
  pais                                  String?
  avatar                                String?
  genero                                Genero?
  direccion                             String?
  activo                                Boolean?                      @default(true)
  fechaRegistro                         DateTime?                     @default(now()) @db.Timestamp(6)
  createdAt                             DateTime?                     @default(now()) @db.Timestamp(6)
  intentos_fallidos_cambio_password     Int                           @default(0)
  bloqueo_cambio_password_hasta         DateTime?                     @db.Timestamptz(6)
  password_actualizado_en               DateTime                      @default(now()) @db.Timestamptz(6)
  two_factor_activo                     Boolean                       @default(false)
  two_factor_metodo                     String                        @default("email") @db.VarChar(20)
  two_factor_activado_en                DateTime?                     @db.Timestamptz(6)
  controlador                           Boolean                       @default(false)
  notificacionWhatsapp                  Boolean?                      @default(false)
  rolId                                 Int?
  notificacion_email                    Boolean?                      @default(true)
  notificacion_whatsapp                 Boolean?                      @default(false)
  fecha_registro                        DateTime?                     @default(now()) @db.Timestamp(6)
  updatedAt                             DateTime?                     @updatedAt @db.Timestamp(6)
  desactivado_en                        DateTime?                     @db.Timestamp(6)
  fecha_nacimiento                      DateTime?                     @db.Timestamp(6)
  telemetria_compartida                 Boolean?                      @default(false)
  zona_conexion                         String?                       @db.VarChar(100)
  autenticacion_social                  autenticacion_social[]
  bitacora_pagos                        bitacora_pagos[]
  blog                                  blog[]
  cambio_email                          CambioEmail[]
  codigo_2fa                            codigo_2fa[]
  comentario                            comentario[]
  comentario_like                       comentario_like[]
  comparacion                           comparacion[]
  entrenamiento_ml                      entrenamiento_ml[]
  favorito                              favorito[]
  historial_busqueda                    historial_busqueda[]
  historial_password                    historial_password[]
  inmuebles                             Inmueble[]
  magic_link                            magic_link[]
  notificaciones                        Notificacion[]
  perfil                                Perfil?
  propiedad_vista                       propiedad_vista[]
  publicaciones                         Publicacion[]
  recuperacion_password                 recuperacion_password[]
  sesiones                              Sesion[]
  suscripciones_activas                 suscripciones_activas[]
  telefonos                             Telefono[]
  telefono_telefono_usuario_idTousuario Telefono[]                    @relation("telefono_usuario_idTousuario")
  testimonio                            testimonio[]
  testimonio_like                       testimonio_like[]
  transacciones                         transacciones[]
  tutorial_publicacion_usuario          tutorial_publicacion_usuario?
  rol                                   Rol?                          @relation(fields: [rolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago                     verificacion_pago[]
  visitor                               Visitor[]
  zona_usuario                          zona_usuario[]

  @@index([correo], map: "idx_usuario_correo")
  @@index([rolId], map: "idx_usuario_rol")
  @@index([rolId], map: "idx_usuario_rol_id")
  @@map("usuario")
}

model Telefono {
  id                                   Int      @id @default(autoincrement())
  codigoPais                           String
  numero                               String
  principal                            Boolean? @default(false)
  usuarioId                            Int
  codigo_pais                          String?
  usuario_id                           Int?
  usuario                              Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario_telefono_usuario_idTousuario Usuario? @relation("telefono_usuario_idTousuario", fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "telefono_usuario_fk")

  @@index([usuario_id], map: "idx_telefono_usuario")
  @@map("telefono")
}

model Sesion {
  id              Int       @id @default(autoincrement())
  token           String    @unique
  fechaInicio     DateTime? @default(now()) @db.Timestamp(6)
  fechaExpiracion DateTime  @db.Timestamp(6)
  estado          Boolean?  @default(true)
  usuarioId       Int
  metodo_auth     String?   @default("email") @db.VarChar(30)
  usuario         Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sesion_usuario_id_fkey")

  @@map("sesion")
}

model Notificacion {
  id            Int       @id @default(autoincrement())
  titulo        String
  mensaje       String
  leida         Boolean   @default(false)
  fechaCreacion DateTime? @default(now()) @db.Timestamp(6)
  fechaLectura  DateTime? @db.Timestamp(6)
  eliminada     Boolean   @default(false)
  archivada     Boolean   @default(false)
  usuarioId     Int
  tipo          String    @default("GENERAL") @db.VarChar(30)
  blog_id       Int?
  blog          blog?     @relation(fields: [blog_id], references: [id], onUpdate: NoAction, map: "notificacion_blog_fk")
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notificacion_usuario_id_fkey")

  @@index([blog_id], map: "idx_notificacion_blog")
  @@index([usuarioId, leida], map: "idx_notificacion_usuario_leida")
  @@map("notificacion")
}

model CambioEmail {
  id            Int       @id @default(autoincrement())
  email_nuevo   String
  token         String    @unique
  expira_en     DateTime  @db.Timestamp(6)
  creado_en     DateTime? @default(now()) @db.Timestamp(6)
  completado_en DateTime? @db.Timestamp(6)
  usuario_id    Int
  usuario       Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("cambio_email")
}

model Perfil {
  id              Int     @id @default(autoincrement())
  nombre_completo String
  datos           Json?
  usuario_id      Int     @unique
  usuario         Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("perfil")
}

model Inmueble {
  id                  Int                   @id @default(autoincrement())
  titulo              String
  tipoAccion          TipoAccion            @map("tipo_accion")
  categoria           Categoria?            @map("categoria")
  precio              Decimal               @db.Decimal(12, 2)
  superficieM2        Decimal?              @map("superficie_m2") @db.Decimal(10, 2)
  nroCuartos          Int?                  @map("nro_cuartos")
  nroBanos            Int?                  @map("nro_banos")
  descripcion         String?
  estado              EstadoInmueble?       @default(ACTIVO) @map("estado")
  fechaPublicacion    DateTime?             @default(now()) @map("fecha_publicacion") @db.Timestamp(6)
  createdAt           DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime?             @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  propietarioId       Int                   @map("propietario_id")
  banoCompartido      Boolean?              @default(false)
  precio_anterior     Decimal?              @db.Decimal(12, 2)
  fecha_reduccion     DateTime?             @db.Timestamp(6)
  detalle_comparacion detalle_comparacion[]
  entrenamiento_ml    entrenamiento_ml[]
  favorito            favorito[]
  propietario         Usuario               @relation(fields: [propietarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inmueble_propietario_fk")
  inmueble_amenidad   inmueble_amenidad[]
  inmueble_etiqueta   InmuebleEtiqueta[]
  marcador_mapa       MarcadorMapa[]
  propiedad_vista     propiedad_vista[]
  publicaciones       Publicacion[]
  ubicacion           UbicacionInmueble?
  puntosDeInteres     punto_interes[]

  @@index([propietarioId], map: "idx_inmueble_propietario")
  @@index([estado], map: "idx_inmueble_estado")
  @@index([tipoAccion], map: "idx_inmueble_tipo_accion")
  @@map("inmueble")
}

model UbicacionInmueble {
  id                 Int                @id @default(autoincrement())
  latitud            Decimal            @db.Decimal(10, 7)
  longitud           Decimal            @db.Decimal(10, 7)
  direccion          String?
  ciudad             String?
  zona               String?
  inmuebleId         Int                @unique @map("inmueble_id")
  ubicacionMaestraId Int?               @map("ubicacion_maestra_id")
  barrio_id          Int?
  verticesDifuminado Json?              @map("vertices_difuminado")
  marcador_mapa      MarcadorMapa[]
  barrio             barrio?            @relation(fields: [barrio_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inmueble           Inmueble           @relation(fields: [inmuebleId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "ubicacion_inmueble_fk")
  ubicacion_maestra  ubicacion_maestra? @relation(fields: [ubicacionMaestraId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ubicacionMaestraId], map: "idx_ubicacion_maestra")
  @@map("ubicacion_inmueble")
}

model Etiqueta {
  id                Int                @id @default(autoincrement())
  nombre            String             @unique
  inmueble_etiqueta InmuebleEtiqueta[]

  @@map("etiqueta")
}

model InmuebleEtiqueta {
  inmueble_id Int
  etiqueta_id Int
  etiqueta    Etiqueta @relation(fields: [etiqueta_id], references: [id], onUpdate: NoAction, map: "inmueble_etiqueta_etiqueta_fk")
  inmueble    Inmueble @relation(fields: [inmueble_id], references: [id], onUpdate: NoAction, map: "inmueble_etiqueta_inmueble_fk")

  @@id([inmueble_id, etiqueta_id])
  @@map("inmueble_etiqueta")
}

model Publicacion {
  id                    Int                     @id @default(autoincrement())
  titulo                String
  descripcion           String?
  estado                EstadoPublicacion?      @default(ACTIVA) @map("estado")
  fechaPublicacion      DateTime?               @default(now()) @map("fecha_publicacion") @db.Timestamp(6)
  usuarioId             Int                     @map("usuario_id")
  inmuebleId            Int                     @map("inmueble_id")
  paymentIntentId       String?                 @map("payment_intent_id")
  promoted              Boolean                 @default(false)
  promotedAt            DateTime?               @map("promoted_at") @db.Timestamp(6)
  promotedExpiresAt     DateTime?               @map("promoted_expires_at") @db.Timestamp(6)
  multimedia            Multimedia[]
  inmueble              Inmueble                @relation(fields: [inmuebleId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "publicacion_inmueble_fk")
  usuario               Usuario                 @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "publicacion_usuario_fk")
  publicacion_parametro publicacion_parametro[]
  publicacion_tag       publicacion_tag[]

  @@index([estado], map: "idx_publicacion_estado")
  @@index([inmuebleId], map: "idx_publicacion_inmueble")
  @@index([usuarioId], map: "idx_publicacion_usuario")
  @@index([promoted], map: "idx_publicacion_promoted")
  @@map("publicacion")
}

model Multimedia {
  id            Int            @id @default(autoincrement())
  url           String
  tipo          TipoMultimedia
  pesoMb        Decimal?       @map("peso_mb") @db.Decimal(8, 2)
  publicacionId Int            @map("publicacion_id")
  publicacion   Publicacion    @relation(fields: [publicacionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "multimedia_publicacion_fk")

  @@index([publicacionId], map: "idx_multimedia_publicacion")
  @@map("multimedia")
}

model MarcadorMapa {
  id                 Int               @id @default(autoincrement())
  tipo               TipoMarcador
  es_visible         Boolean?          @default(true)
  nivel_z            Int?
  inmueble_id        Int
  ubicacion_id       Int
  detalle_grupo      DetalleGrupo[]
  interaccion_mapa   InteraccionMapa[]
  inmueble           Inmueble          @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ubicacion_inmueble UbicacionInmueble @relation(fields: [ubicacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("marcador_mapa")
}

model GrupoMarcadores {
  id                 Int            @id @default(autoincrement())
  latitud_centro     Decimal        @db.Decimal(10, 7)
  longitud_centro    Decimal        @db.Decimal(10, 7)
  cantidad_inmuebles Int
  nivel_color        String?
  nivel_zoom         Int
  radio_km           Decimal?       @db.Decimal(10, 2)
  actualizado_en     DateTime?      @default(now()) @db.Timestamp(6)
  detalle_grupo      DetalleGrupo[]

  @@map("grupo_marcadores")
}

model DetalleGrupo {
  grupo_id         Int
  marcador_id      Int
  grupo_marcadores GrupoMarcadores @relation(fields: [grupo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  marcador_mapa    MarcadorMapa    @relation(fields: [marcador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([grupo_id, marcador_id])
  @@map("detalle_grupo")
}

model SesionMapa {
  id               Int               @id @default(autoincrement())
  token            String            @unique
  limite_norte     Decimal?          @db.Decimal(10, 7)
  limite_sur       Decimal?          @db.Decimal(10, 7)
  limite_este      Decimal?          @db.Decimal(10, 7)
  limite_oeste     Decimal?          @db.Decimal(10, 7)
  nivel_zoom       Int
  latitud_centro   Decimal?          @db.Decimal(10, 7)
  longitud_centro  Decimal?          @db.Decimal(10, 7)
  iniciado_en      DateTime?         @default(now()) @db.Timestamp(6)
  ultima_actividad DateTime?         @default(now()) @db.Timestamp(6)
  interaccion_mapa InteraccionMapa[]

  @@map("sesion_mapa")
}

model InteraccionMapa {
  id               Int             @id @default(autoincrement())
  tipo             TipoInteraccion
  latitud_momento  Decimal?        @db.Decimal(10, 7)
  longitud_momento Decimal?        @db.Decimal(10, 7)
  zoom_momento     Int?
  ocurrio_en       DateTime?       @default(now()) @db.Timestamp(6)
  sesion_id        Int?
  marcador_id      Int?
  marcador_mapa    MarcadorMapa?   @relation(fields: [marcador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sesion_mapa      SesionMapa?     @relation(fields: [sesion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("interaccion_mapa")
}

model banner_home {
  id             Int       @id @default(autoincrement())
  url_imagen     String
  orden          Int
  activo         Boolean?  @default(true)
  fecha_creacion DateTime? @default(now()) @db.Timestamp(6)
  titulo         String?
  subtitulo      String?

  @@map("banner_home")
}

model Visitor {
  id           Int       @id @default(autoincrement())
  ip           String
  meta_data    Json?
  fecha_visita DateTime? @default(now()) @db.Timestamp(6)
  usuario_id   Int?
  token        String?   @unique
  usuario      Usuario?  @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("visitor")
}

model ubicacion_maestra {
  id                 Int                 @id @default(autoincrement())
  departamento       String
  provincia          String?
  municipio          String?
  nombre             String
  latitud            Decimal             @db.Decimal(10, 7)
  longitud           Decimal             @db.Decimal(10, 7)
  popularidad        Int?                @default(0)
  ubicacion_inmueble UbicacionInmueble[]

  @@index([nombre], map: "idx_ubicacion_nombre")
}

model bitacora_pagos {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  evento           String            @db.VarChar(100)
  mensaje          String?
  fecha_evento     DateTime?         @default(now()) @db.Timestamp(6)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          Usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([fecha_evento], map: "idx_bitacora_fecha")
}

model plan_suscripcion {
  id                     Int                     @id @default(autoincrement())
  nombre_plan            String?                 @db.VarChar(50)
  descripcion_plan       String?
  precio_plan            Decimal?                @db.Decimal(10, 2)
  duracion_plan_dias     Int?
  nro_publicaciones_plan Int?
  imagen_gr_url          String?                 @db.VarChar(255)
  eliminado_en           DateTime?               @db.Timestamptz(6)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  transacciones          transacciones[]
}

model suscripciones_activas {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  fecha_inicio     DateTime          @db.Timestamp(6)
  fecha_fin        DateTime          @db.Timestamp(6)
  estado           String?           @default("INACTIVA") @db.VarChar(20)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          Usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model transacciones {
  id                     Int                     @id @default(autoincrement())
  id_usuario             Int
  id_suscripcion         Int
  subtotal               Decimal                 @db.Decimal(10, 2)
  iva_porcentaje         Decimal                 @db.Decimal(5, 2)
  iva_monto              Decimal                 @db.Decimal(10, 2)
  total                  Decimal                 @db.Decimal(10, 2)
  metodo_pago            String?                 @default("QR_BANCARIO") @db.VarChar(30)
  fecha_intento          DateTime?               @default(now()) @db.Timestamp(6)
  fecha_completado       DateTime?               @db.Timestamp(6)
  estado                 String?                 @default("PENDIENTE") @db.VarChar(20)
  verificacion_requerida Boolean?                @default(true)
  tiempo_activacion      DateTime?               @db.Timestamp(6)
  cupon_id               Int?
  monto_descuento        Decimal?                @default(0) @db.Decimal(10, 2)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  cupon                  cupon?                  @relation(fields: [cupon_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  plan_suscripcion       plan_suscripcion        @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario                Usuario                 @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago      verificacion_pago[]

  @@index([estado], map: "idx_transacciones_estado")
  @@index([id_usuario], map: "idx_transacciones_usuario")
}

model verificacion_pago {
  id                     Int            @id @default(autoincrement())
  id_transaccion         Int?
  id_admin               Int
  fecha_verificacion     DateTime?      @default(now()) @db.Timestamp(6)
  resultado_verificacion String?        @default("VERIFICADO") @db.VarChar(20)
  usuario                Usuario        @relation(fields: [id_admin], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones          transacciones? @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ZonaPredefinida {
  id          Int      @id @default(autoincrement())
  nombre      String
  coordenadas Json
  color       String   @default("#ea580c")
  activa      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  @@map("zona_predefinida")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model audit_log {
  id          Int       @default(autoincrement())
  query       String?
  executed_at DateTime? @default(now()) @db.Timestamp(6)

  @@ignore
}

model autenticacion_social {
  id                   Int       @id @default(autoincrement())
  usuarioId            Int
  proveedor            String    @db.VarChar(30)
  correoProveedor      String?   @db.VarChar(100)
  idExterno            String    @db.VarChar(150)
  vinculadoEn          DateTime? @default(now()) @db.Timestamp(6)
  activo               Boolean?  @default(true)
  token_acceso_cifrado String?
  token_expira_en      DateTime? @db.Timestamptz(6)
  ultimo_uso_en        DateTime? @db.Timestamptz(6)
  usuario              Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([proveedor, idExterno], map: "autenticacion_social_proveedor_idexterno_key")
  @@unique([usuarioId, proveedor], map: "autenticacion_social_usuario_proveedor_key")
}

model codigo_2fa {
  id         Int       @id @default(autoincrement())
  usuarioId  Int
  codigoHash String    @db.VarChar(255)
  creadoEn   DateTime? @default(now()) @db.Timestamp(6)
  expiraEn   DateTime  @db.Timestamp(6)
  usadoEn    DateTime? @db.Timestamp(6)
  intentos   Int?      @default(0)
  activo     Boolean?  @default(true)
  usuario    Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "codigo_2fa_usuario_fecha_idx")
}

model comparacion {
  id                  Int                   @id @default(autoincrement())
  nombre              String?               @db.VarChar(100)
  creadoEn            DateTime              @default(now())
  usuarioId           Int
  activo              Boolean               @default(true)
  usuario             Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  detalle_comparacion detalle_comparacion[]
}

model detalle_comparacion {
  id            Int         @id @default(autoincrement())
  comparacionId Int
  inmuebleId    Int
  orden         Int         @default(0)
  comparacion   comparacion @relation(fields: [comparacionId], references: [id], onDelete: Cascade)
  inmueble      Inmueble    @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)

  @@unique([comparacionId, inmuebleId])
}

model favorito {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  inmuebleId Int
  agregadoEn DateTime @default(now())
  inmueble   Inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, inmuebleId])
}

model historial_password {
  id           Int       @id @default(autoincrement())
  usuarioId    Int
  passwordHash String    @db.VarChar(255)
  creadoEn     DateTime? @default(now()) @db.Timestamp(6)
  usuario      Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "historial_password_usuario_fecha_idx")
}

model propiedad_vista {
